{
    "name": "webview-example",
    "displayName": "Webview Example",
    "description": "A minimal VS Code extension demonstrating Webview usage.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.0.0"
    },
    "contributes": {
        "commands": [
            {
                "command": "webviewExample.show",
                "title": "Show Webview Example"
            }
        ]
    }
}